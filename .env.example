# Root environment example for local development

# Frontend: OpenRouteService API Key
# Get your API key from: https://openrouteservice.org/dev/#/login
NEXT_PUBLIC_OPENROUTESERVICE_API_KEY=your_openrouteservice_api_key_here

# Frontend: Backend API base URL (optional). If your backend runs on a different origin/port set this,
# e.g. NEXT_PUBLIC_API_BASE=http://localhost:5000
# When empty, frontend will call relative `/api/...` paths.
NEXT_PUBLIC_API_BASE=http://localhost:5000

# Backend: ASP.NET Core environment
ASPNETCORE_ENVIRONMENT=Development
# Backend URL binding (Kestrel)
DOTNET_URLS=http://localhost:5000
